<div class="container">
  <div class="row">
    <div class="col-lg-6 mx-auto mt-5">
      <div class="card border-danger">
        <div class="card-header text-center bg-danger text-white">
          <h4>Payment Cancelled</h4>
        </div>
        <div class="card-body text-center">
          <p class="mt-3">Aapka payment complete nahi hua.</p>
          <p>Seats abhi bhi available hain — dobara try kar sakte hain.</p>
          <div class="mt-3">
            <%= link_to "Try Again", new_booking_path(booking: { show_id: @show.id }), class: "btn btn-outline-danger" %>
            <%= link_to "My Bookings", bookings_path, class: "btn btn-outline-primary" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>